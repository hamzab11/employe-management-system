<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.CreateUserController"
            prefWidth="900"
            prefHeight="600"
            style="-fx-background-color: white;">

    <!--
        AnimationManager suggestion:
        Apply fade animation to the whole root/page if you want.
    -->

    <!-- Right Blue Pane -->
    <Pane fx:id="rightBluePane"
          layoutX="570"
          prefWidth="330"
          prefHeight="600"
          style="-fx-background-color: #2347D5;">

        <!--
            AnimationManager suggestion:
            Apply subtle slide/fade animation to rightBluePane.
        -->

        <children>

            <Circle fx:id="circleOne"
                    centerX="100"
                    centerY="70"
                    radius="18"
                    fill="transparent"
                    stroke="#9DB4FF"
                    strokeWidth="1.5"/>

            <Circle fx:id="circleTwo"
                    centerX="270"
                    centerY="520"
                    radius="22"
                    fill="transparent"
                    stroke="#9DB4FF"
                    strokeWidth="1.5"/>

            <!--
                AnimationManager suggestion:
                Apply slow floating animation to circleOne and circleTwo.
            -->

        </children>
    </Pane>

    <!-- Main Card -->
    <VBox fx:id="mainCard"
          spacing="22"
          alignment="CENTER"
          layoutX="150"
          layoutY="70"
          prefWidth="620"
          prefHeight="460"
          style="-fx-background-color: white;
                 -fx-background-radius: 24;
                 -fx-padding: 40;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 18, 0, 0, 4);">

        <!--
            AnimationManager suggestion:
            Apply fadeIn(mainCard)
            Apply slideFromRight(mainCard)
            This will make it compatible with the login page.
        -->

        <Label text="Authority Gate"
               style="-fx-text-fill: #2347D5;
                      -fx-font-size: 18px;
                      -fx-font-weight: bold;"/>

        <Label text="Create System User"
               style="-fx-text-fill: #111827;
                      -fx-font-size: 34px;
                      -fx-font-weight: 300;"/>

        <Label text="Only administrators can create MANAGER or USER accounts"
               style="-fx-text-fill: #9CA3AF;
                      -fx-font-size: 14px;"/>

        <VBox spacing="6" alignment="CENTER_LEFT">

            <Label text="Username"
                   style="-fx-text-fill: #111827;
                          -fx-font-size: 15px;"/>

            <TextField fx:id="usernameField"
                       promptText="Enter username"
                       maxWidth="370"
                       prefHeight="48"
                       style="-fx-background-color: white;
                              -fx-border-color: #D1D5DB;
                              -fx-border-radius: 8;
                              -fx-background-radius: 8;
                              -fx-font-size: 14px;"/>

            <!--
                AnimationManager suggestion:
                nodeHover(usernameField)
            -->

        </VBox>

        <VBox spacing="6" alignment="CENTER_LEFT">

            <Label text="Password"
                   style="-fx-text-fill: #111827;
                          -fx-font-size: 15px;"/>

            <PasswordField fx:id="passwordField"
                           promptText="Enter password"
                           maxWidth="370"
                           prefHeight="48"
                           style="-fx-background-color: white;
                                  -fx-border-color: #D1D5DB;
                                  -fx-border-radius: 8;
                                  -fx-background-radius: 8;
                                  -fx-font-size: 14px;"/>

            <!--
                AnimationManager suggestion:
                nodeHover(passwordField)
            -->

        </VBox>

        <VBox spacing="6" alignment="CENTER_LEFT">

            <Label text="Role"
                   style="-fx-text-fill: #111827;
                          -fx-font-size: 15px;"/>

            <ComboBox fx:id="roleComboBox"
                      promptText="Select role"
                      maxWidth="370"
                      prefHeight="48"
                      style="-fx-background-color: white;
                             -fx-border-color: #D1D5DB;
                             -fx-border-radius: 8;
                             -fx-background-radius: 8;
                             -fx-font-size: 14px;"/>

            <!--
                AnimationManager suggestion:
                nodeHover(roleComboBox)
            -->

        </VBox>

        <Label fx:id="messageLabel"
               wrapText="true"
               maxWidth="370"
               style="-fx-text-fill: #D97706;
                      -fx-font-size: 13px;"/>

        <!--
            AnimationManager suggestion:
            On errors:
            shake(messageLabel, 10, -10, 10, 6, true)
        -->

        <HBox spacing="16" alignment="CENTER">

            <Button fx:id="createUserButton"
                    text="Create User"
                    onAction="#handleCreateUser"
                    prefWidth="190"
                    prefHeight="48"
                    style="-fx-background-color: #2347D5;
                           -fx-text-fill: white;
                           -fx-font-size: 15px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;"/>

            <!--
                AnimationManager suggestion:
                nodeHover(createUserButton)
            -->

            <Button fx:id="backButton"
                    text="Back"
                    onAction="#handleBack"
                    prefWidth="130"
                    prefHeight="48"
                    style="-fx-background-color: white;
                           -fx-text-fill: #2347D5;
                           -fx-font-size: 15px;
                           -fx-font-weight: bold;
                           -fx-border-color: #2347D5;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;"/>

            <!--
                AnimationManager suggestion:
                nodeHover(backButton)
            -->

        </HBox>

    </VBox>

</AnchorPane>